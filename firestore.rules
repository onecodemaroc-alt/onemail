rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check auth
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function getUserRole() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Users — owner only, admins can read all
    match /users/{userId} {
      allow read: if isOwner(userId) || getUserRole() == 'admin';
      allow write: if isOwner(userId);
    }

    // SMTP Accounts — only authenticated users can manage
    match /smtpAccounts/{accountId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // Contacts — only authenticated users
    match /contacts/{contactId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // Contact Lists
    match /contactLists/{listId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // Email Templates
    match /templates/{templateId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // Campaigns
    match /campaigns/{campaignId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // Email Logs
    match /emailLogs/{logId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // Config (readable by authenticated users)
    match /config/{docId} {
      allow read: if isAuth();
    }

    // Inbox (received emails)
    match /inbox/{emailId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // Quick Sends
    match /quickSends/{sendId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }
  }
}
